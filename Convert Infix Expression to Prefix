#include <stdio.h>
#include <string.h>
#include <ctype.h>

#define MAX 101

char stack[MAX];
int top = -1;

void push(char c) {
    stack[++top] = c;
}

char pop() {
    return stack[top--];
}

char peek() {
    return stack[top];
}

int precedence(char op) {
    if (op == '+' || op == '-') return 1;
    if (op == '*' || op == '/') return 2;
    if (op == '^') return 3;
    return 0;
}

int isRightAssociative(char op) {
    if (op == '^') return 1;
    return 0;
}

void reverse(char *exp) {
    int n = strlen(exp);
    int i;
    for (i = 0; i < n / 2; i++) {
        char temp = exp[i];
        exp[i] = exp[n - i - 1];
        exp[n - i - 1] = temp;
    }
}

int main() {
    char infix[MAX];
    char postfix[MAX];
    int i, k = 0;

    scanf("%s", infix);

    reverse(infix);

    for (i = 0; infix[i] != '\0'; i++) {
        if (infix[i] == '(')
            infix[i] = ')';
        else if (infix[i] == ')')
            infix[i] = '(';
    }

    for (i = 0; infix[i] != '\0'; i++) {

        if (isalnum(infix[i])) {
            postfix[k++] = infix[i];
        }

        else if (infix[i] == '(') {
            push(infix[i]);
        }

        else if (infix[i] == ')') {
            while (top != -1 && peek() != '(') {
                postfix[k++] = pop();
            }
            pop();
        }

        else {
            while (top != -1 &&
                  (precedence(peek()) > precedence(infix[i]) ||
                  (precedence(peek()) == precedence(infix[i]) &&
                   isRightAssociative(peek())))) {
                postfix[k++] = pop();
            }
            push(infix[i]);
        }
    }

    while (top != -1) {
        postfix[k++] = pop();
    }
