#include <stdio.h>

int main() {
    int n, k;
    int tickets[100];
    int time = 0;

    scanf("%d", &n);

    for(int i = 0; i < n; i++) {
        scanf("%d", &tickets[i]);
    }

    scanf("%d", &k);

    for(int i = 0; i < n; i++) {
        if(i <= k) {
            time += (tickets[i] < tickets[k]) ? tickets[i] : tickets[k];
        } else {
            int limit = tickets[k] - 1;
            time += (tickets[i] < limit) ? tickets[i] : limit;
        }
    }

    printf("%d\n", time);

    return 0;
}
