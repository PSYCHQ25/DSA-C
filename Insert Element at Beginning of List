#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
#include <stdio.h>

int main() {
    int N, X;
    int arr[100];

    // Read size
    scanf("%d", &N);

    // Read array elements
    for(int i = 0; i < N; i++) {
        scanf("%d", &arr[i]);
    }

    // Read element to insert
    scanf("%d", &X);

    // Shift elements to the right
    for(int i = N; i > 0; i--) {
        arr[i] = arr[i - 1];
    }

    // Insert X at beginning
    arr[0] = X;

    // Print updated array
    for(int i = 0; i <= N; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}

