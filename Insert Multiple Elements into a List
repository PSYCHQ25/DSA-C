#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
#include <stdio.h>

int main() {
    int N, K;
    int arr[100];
    
    // Read initial size
    scanf("%d", &N);

    // Read initial elements
    for(int i = 0; i < N; i++) {
        scanf("%d", &arr[i]);
    }

    // Read number of insert operations
    scanf("%d", &K);

    for(int i = 0; i < K; i++) {
        int X, P;
        scanf("%d %d", &X, &P);

        // Shift elements to the right
        for(int j = N; j > P; j--) {
            arr[j] = arr[j - 1];
        }

        // Insert element
        arr[P] = X;

        // Increase current size
        N++;
    }

    // Print final array
    for(int i = 0; i < N; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}

