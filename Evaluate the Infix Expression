#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>
#include <math.h>

#define MAX 200

long long values[MAX];
char ops[MAX];
int vtop = -1;
int otop = -1;

void pushValue(long long val) {
    values[++vtop] = val;
}

long long popValue() {
    return values[vtop--];
}

void pushOp(char op) {
    ops[++otop] = op;
}

char popOp() {
    return ops[otop--];
}

char peekOp() {
    return ops[otop];
}

int precedence(char op) {
    if (op == '+' || op == '-') return 1;
    if (op == '*' || op == '/') return 2;
    if (op == '^') return 3;
    return 0;
}

int isRightAssociative(char op) {
    if (op == '^') return 1;
    return 0;
}

long long applyOp(long long a, long long b, char op) {
    if (op == '+') return a + b;
    if (op == '-') return a - b;
    if (op == '*') return a * b;
    if (op == '/') return a / b;
    if (op == '^') return (long long)pow(a, b);
    return 0;
}

int main() {
    char expr[101];
    scanf("%s", expr);

    int i = 0;
    int len = strlen(expr);

    while (i < len) {

        if (isdigit(expr[i])) {
            long long val = 0;
            while (i < len && isdigit(expr[i])) {
                val = val * 10 + (expr[i] - '0');
                i++;
            }
            pushValue(val);
            continue;
        }

        else if (expr[i] == '(') {
            pushOp(expr[i]);
        }

        else if (expr[i] == ')') {
            while (otop >= 0 && peekOp() != '(') {
                long long b = popValue();
                long long a = popValue();
                pushValue(applyOp(a, b, popOp()));
            }
            popOp();
        }

        else {
            while (otop >= 0 &&
                  (precedence(peekOp()) > precedence(expr[i]) ||
                  (precedence(peekOp()) == precedence(expr[i]) &&
                   !isRightAssociative(expr[i])))) {

                long long b = popValue();
                long long a = popValue();
                pushValue(applyOp(a, b, popOp()));
            }
            pushOp(expr[i]);
        }

        i++;
    }

    while (otop >= 0) {
        long long b = popValue();
        long long a = popValue();
        pushValue(applyOp(a, b, popOp()));
    }

    printf("%lld\n", popValue());
    return 0;
}
