#include <stdio.h>
#include <string.h>

#define MAX 101

int main() {
    char s[MAX];
    scanf("%s", s);

    int n = strlen(s);

    if (n == 0) {
        return 0;
    }

    // Print first character
    printf("%c", s[0]);

    // Traverse and remove consecutive duplicates
    for (int i = 1; i < n; i++) {
        if (s[i] != s[i - 1]) {
            printf("%c", s[i]);
        }
    }

    printf("\n");
    return 0;
}
