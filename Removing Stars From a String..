#include <stdio.h>
#include <string.h>

#define MAX 101

int main() {
    char s[MAX];
    char stack[MAX];
    int top = -1;

    scanf("%s", s);

    for (int i = 0; s[i] != '\0'; i++) {
        if (s[i] == '*') {
            if (top >= 0) {
                top--;  // remove closest non-star character
            }
        } else {
            stack[++top] = s[i];  // push character
        }
    }

    stack[top + 1] = '\0';  // null terminate string
    printf("%s\n", stack);

    return 0;
}
