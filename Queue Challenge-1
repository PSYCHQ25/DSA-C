#include <stdio.h>

int main() {
    int N, Q;
    scanf("%d", &N);
    scanf("%d", &Q);

    int queue[N];
    int front = -1, rear = -1;

    while(Q--) {
        int type;
        scanf("%d", &type);

        if(type == 1) {  // Enqueue
            int x;
            scanf("%d", &x);

            if(rear == N - 1) {
                printf("Queue Overflow\n");
            } else {
                if(front == -1) front = 0;
                queue[++rear] = x;
            }
        }

        else if(type == 2) {  // Dequeue
            if(front == -1 || front > rear) {
                printf("Queue Underflow\n");
            } else {
                printf("%d\n", queue[front++]);
            }
        }

        else if(type == 3) {  // Peek
            if(front == -1 || front > rear) {
                printf("Queue Underflow\n");
            } else {
                printf("%d\n", queue[front]);
            }
        }

        else if(type == 4) {  // Display
            if(front == -1 || front > rear) {
                printf("Queue is Empty\n");
            } else {
                for(int i = front; i <= rear; i++) {
                    printf("%d", queue[i]);
                    if(i < rear) printf(" ");
                }
                printf("\n");
            }
        }
    }

    return 0;
}
