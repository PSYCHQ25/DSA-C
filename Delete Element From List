#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
#include <stdio.h>

int main() {
    int n;
    scanf("%d", &n);

    int list[n];

    for (int i = 0; i < n; i++) {
        scanf("%d", &list[i]);
    }

    int val;
    scanf("%d", &val);

    int found = 0;

    for (int i = 0; i < n; i++) {
        if (list[i] == val) {
            found = 1;
            for (int j = i; j < n - 1; j++) {
                list[j] = list[j + 1];
            }
            n--;
            break;
        }
    }

    for (int i = 0; i < n; i++) {
        printf("%d ", list[i]);
    }

    return 0;
}
