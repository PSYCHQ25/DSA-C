#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
#include <stdio.h>

int main() {
    int N;
    int stack[100];

    // Read number of elements
    scanf("%d", &N);

    // Read elements into the stack
    for(int i = 0; i < N; i++) {
        scanf("%d", &stack[i]);
    }

    // Sort elements in descending order (simple bubble sort)
    for(int i = 0; i < N - 1; i++) {
        for(int j = 0; j < N - i - 1; j++) {
            if(stack[j] < stack[j + 1]) {
                int temp = stack[j];
                stack[j] = stack[j + 1];
                stack[j + 1] = temp;
            }
        }
    }

    // Print stack elements in descending order
    for(int i = 0; i < N; i++) {
        printf("%d ", stack[i]);
    }

    return 0;
}
