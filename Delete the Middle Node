#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
struct Node {
    int data;
    struct Node* next;
};

struct Node* head = NULL;


struct Node* createNode(int data) {
    struct Node* temp = (struct Node*)malloc(sizeof(struct Node));
    temp->data = data;
    temp->next = NULL;
    return temp;
}


void display() {
    if (head == NULL) {
        printf("EMPTY");
        return;
    }

    struct Node* temp = head;
    while (temp != NULL) {
        printf("%d ", temp->data);
        temp = temp->next;
    }
}

int main() {
    int n, val;
    scanf("%d", &n);

    struct Node* tail = NULL;

    
    for (int i = 0; i < n; i++) {
        scanf("%d", &val);
        struct Node* newNode = createNode(val);

        if (head == NULL)
            head = newNode;
        else
            tail->next = newNode;

        tail = newNode;
    }

    
    if (n == 1) {
        head = NULL;
    } else {
        int mid = n / 2;   

        
        if (mid == 0) {
            head = head->next;
        } else {
            struct Node* temp = head;

            
            for (int i = 0; i < mid - 1; i++) {
                temp = temp->next;
            }

            
            temp->next = temp->next->next;
        }
    }

    display();
    return 0;
}
  
    
