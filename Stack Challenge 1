#include <stdio.h>
#include <stdlib.h>

int max, top = -1;
int stack[100];

void push(int value) {
    if (top == max - 1)
        printf("Overflow\n");
    else
        stack[++top] = value;
}

void pop() {
    if (top == -1)
        printf("Underflow\n");
    else
        printf("Popped: %d\n", stack[top--]);
}

void display() {
    if (top == -1) {
        printf("Stack is Empty\n");
    } else {
        printf("Remaining Stack:\n");
        for (int i = top; i >= 0; i--) {
            printf("%d\n", stack[i]);
        }
    }
}

int main() {
    scanf("%d", &max);

    // Step-1 : Push 3 elements into the stack
    for (int i = 0; i < 3; i++) {
        int val;
        scanf("%d", &val);
        push(val);
    }

    // Step-2 : Pop 1 element
    pop();

    // Step-3 : Push 2 elements
    for (int i = 0; i < 2; i++) {
        int val;
        scanf("%d", &val);
        push(val);
    }

    // Step-4 : Pop 3 elements
    for (int i = 0; i < 3; i++) {
        pop();
    }

    // Step-5 : Display remaining elements
    display();

    return 0;
}

