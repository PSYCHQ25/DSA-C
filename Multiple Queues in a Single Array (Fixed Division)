#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
int main() {
    int N, K, Q;
    scanf("%d %d", &N, &K);

    int size = N / K;
    int arr[100];
    int front[10], rear[10];

    for(int i = 0; i < K; i++) {
        front[i] = -1;
        rear[i] = -1;
    }

    scanf("%d", &Q);

    while(Q--) {
        char op[10];
        int q, x;

        scanf("%s", op);

        if(strcmp(op, "ENQUEUE") == 0) {
            scanf("%d %d", &q, &x);
            int start = (q-1) * size;
            int end = start + size - 1;

            if(rear[q-1] == end) {
                printf("Queue Overflow\n");
            } else {
                if(front[q-1] == -1)
                    front[q-1] = start;
                rear[q-1]++;
                arr[rear[q-1]] = x;
            }
        }

        else if(strcmp(op, "DEQUEUE") == 0) {
            scanf("%d", &q);

            if(front[q-1] == -1 || front[q-1] > rear[q-1]) {
                printf("Queue Underflow\n");
            } else {
                printf("%d\n", arr[front[q-1]]);
                front[q-1]++;
            }
        }

        else if(strcmp(op, "PEEK") == 0) {
            scanf("%d", &q);

            if(front[q-1] == -1 || front[q-1] > rear[q-1]) {
                printf("Queue Underflow\n");
            } else {
                printf("%d\n", arr[front[q-1]]);
            }
        }

        else if(strcmp(op, "DISPLAY") == 0) {
            scanf("%d", &q);

            if(front[q-1] == -1 || front[q-1] > rear[q-1]) {
                printf("Queue Underflow\n");
            } else {
                for(int i = front[q-1]; i <= rear[q-1]; i++) {
                    printf("%d ", arr[i]);
                }
                printf("\n");
            }
        }
    }

    return 0;
}
