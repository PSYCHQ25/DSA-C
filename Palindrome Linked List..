#include <stdio.h>
#include <stdlib.h>

// Define a node of linked list
struct Node {
    int data;
    struct Node* next;
};

// Function to create a new node
struct Node* newNode(int val) {
    struct Node* node = (struct Node*)malloc(sizeof(struct Node));
    node->data = val;
    node->next = NULL;
    return node;
}

int main() {
    int n, i, val;
    scanf("%d", &n);

    struct Node *head = NULL, *tail = NULL;

    // create linked list
    for(i = 0; i < n; i++) {
        scanf("%d", &val);
        struct Node* node = newNode(val);
        if(head == NULL) {
            head = tail = node;
        } else {
            tail->next = node;
            tail = node;
        }
    }

    // store elements in array to check palindrome
    int arr[n], rev[n];
    struct Node* temp = head;
    for(i = 0; i < n; i++) {
        arr[i] = temp->data;
        temp = temp->next;
    }

    // reverse array
    for(i = 0; i < n; i++) {
        rev[i] = arr[n - i - 1];
    }

    // check palindrome
    int isPalindrome = 1;
    for(i = 0; i < n; i++) {
        if(arr[i] != rev[i]) {
            isPalindrome = 0;
            break;
        }
    }

    // print result
    if(isPalindrome) {
        printf("Palindrome : ");
    } else {
        printf("Not Palindrome : ");
    }

    // print reversed list
    for(i = 0; i < n; i++) {
        printf("%d ", rev[i]);
    }

    return 0;
}
