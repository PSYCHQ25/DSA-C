#include <stdio.h>

int main() {
    int N;
    scanf("%d", &N);

    int students[N], sandwiches[N];
    int count0 = 0, count1 = 0;

    // Read student preferences
    for(int i = 0; i < N; i++) {
        scanf("%d", &students[i]);
        if(students[i] == 0) count0++;
        else count1++;
    }

    // Read sandwiches
    for(int i = 0; i < N; i++) {
        scanf("%d", &sandwiches[i]);
    }

    for(int i = 0; i < N; i++) {
        if(sandwiches[i] == 0) {
            if(count0 == 0) {
                printf("%d\n", N - i);
                return 0;
            }
            count0--;
        }
        else {
            if(count1 == 0) {
                printf("%d\n", N - i);
                return 0;
            }
            count1--;
        }
    }

    printf("0\n");
    return 0;
}
