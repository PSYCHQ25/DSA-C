#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
#include <stdio.h>
int main() {
    int n;
    scanf("%d", &n);

    int list[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &list[i]);
    }

    int key;
    scanf("%d", &key);

    int found = 0;

    
    for (int i = 0; i < n; i++) {
        if (list[i] == key) {
            found = 1;
            break;
        }
    }

    if (found == 1) {
        printf("Found");
    } else {
        printf("Not Found");
    }

    return 0;
}
