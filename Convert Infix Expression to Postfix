#include <stdio.h>
#include <string.h>
#include <ctype.h>

#define MAX 101

char stack[MAX];
int top = -1;

void push(char c) {
    stack[++top] = c;
}

char pop() {
    return stack[top--];
}

char peek() {
    return stack[top];
}

int precedence(char op) {
    if (op == '+' || op == '-') return 1;
    if (op == '*' || op == '/') return 2;
    if (op == '^') return 3;
    return 0;
}

int isRightAssociative(char op) {
    if (op == '^') return 1;
    return 0;
}

int main() {
    char infix[MAX];
    scanf("%s", infix);

    for (int i = 0; infix[i] != '\0'; i++) {

        if (isalnum(infix[i])) {
            printf("%c", infix[i]);
        }

        else if (infix[i] == '(') {
            push(infix[i]);
        }

        else if (infix[i] == ')') {
            while (top != -1 && peek() != '(') {
                printf("%c", pop());
            }
            pop(); // remove '('
        }

        else { // operator
            while (top != -1 &&
                  (precedence(peek()) > precedence(infix[i]) ||
                  (precedence(peek()) == precedence(infix[i]) &&
                   !isRightAssociative(infix[i])))) {
                printf("%c", pop());
            }
            push(infix[i]);
        }
    }

    while (top != -1) {
        printf("%c", pop());
    }

    printf("\n");
    return 0;
}
